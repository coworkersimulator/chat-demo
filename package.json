{
  "name": "chat",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "pglite:server:memory": "pglite-server --extensions pgcrypto,uuid-ossp --db=memory://",
    "kysely:codegen": "tsx db/kysely-codegen.ts",
    "test": "tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.3",
    "@electric-sql/pglite-repl": "^0.3.3",
    "kysely": "^0.28.15",
    "kysely-pglite-dialect": "^1.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@electric-sql/pglite-react": "^0.3.3",
    "@electric-sql/pglite-socket": "^0.1.3",
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "kysely-codegen": "^0.20.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3"
  }
