{
  "name": "chat",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "pglite:server:bare": "pglite-server --extensions pgcrypto,@electric-sql/pglite/contrib/uuid_ossp:uuid_ossp --db=memory://",
    "pglite:server": "tsx db/server.ts",
    "prisma:pull": "tsx db/prisma-pull.ts",
    "prisma:pull:bare": "prisma db pull --force && npx prisma-case-format --file prisma/schema.prisma && tsx prisma/rename-relations.ts && prisma generate",
    "kysely:codegen": "tsx db/kysely-codegen.ts",
    "test": "tsx --test test/unit/**/*.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.3",
    "@electric-sql/pglite-repl": "^0.3.3",
    "@multiavatar/multiavatar": "^1.0.7",
    "@prisma/client": "^7.7.0",
    "date-fns": "^4.1.0",
    "kysely": "^0.28.15",
    "kysely-pglite-dialect": "^1.3.1",
    "pglite-prisma-adapter": "^0.7.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite-plugin-wasm": "^3.6.0"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13"
  },
  "devDependencies": {
    "@electric-sql/pglite-react": "^0.3.3",
    "@electric-sql/pglite-socket": "^0.1.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "kysely-codegen": "^0.20.0",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.7"
  }
}
