generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["nativeDistinct", "partialIndexes", "strictUndefinedChecks"]
}

datasource db {
  provider = "postgres"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model File {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seq       String    @unique @default(dbgenerated("uuidv7_now()")) @db.Uuid
  filename  String?
  mime      String
  data      Bytes
  createdBy String    @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  meta      Json?
  user      User      @relation(fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([createdAt])
  @@index([createdBy])
  @@index([deletedAt])
  @@index([filename])
  @@index([meta], type: Gin)
  @@index([mime])
  @@map("file")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Note {
  id                             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seq                            String         @unique @default(dbgenerated("uuidv7_now()")) @db.Uuid
  title                          String?
  body                           String?
  createdBy                      String         @map("created_by") @db.Uuid
  createdAt                      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt                      DateTime?      @map("deleted_at") @db.Timestamptz(6)
  meta                           Json?
  user                           User           @relation(fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  asChild   NoteNote[]     @relation("NoteAsChild")
  asParent NoteNote[]     @relation("NoteAsParent")
  noteReaction                   NoteReaction[]
  noteTag                        NoteTag[]
  noteUser                       NoteUser[]

  @@index([createdAt])
  @@index([createdBy])
  @@index([deletedAt])
  @@index([meta], type: Gin)
  @@index([title])
  @@map("note")
}

model NoteNote {
  id                         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seq                        String    @unique @default(dbgenerated("uuidv7_now()")) @db.Uuid
  noteId                     String    @map("note_id") @db.Uuid
  parentId                   String    @map("parent_id") @db.Uuid
  createdBy                  String    @map("created_by") @db.Uuid
  createdAt                  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt                  DateTime? @map("deleted_at") @db.Timestamptz(6)
  meta                       Json?
  user                       User      @relation(fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  note   Note      @relation("NoteAsChild", fields: [noteId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parent Note      @relation("NoteAsParent", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([noteId, parentId], map: "note_note_uniq", where: raw("(deleted_at IS NULL)"))
  @@index([createdAt])
  @@index([createdBy])
  @@index([deletedAt])
  @@index([meta], type: Gin)
  @@index([noteId])
  @@index([parentId])
  @@map("note_note")
}

model NoteReaction {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seq        String    @unique @default(dbgenerated("uuidv7_now()")) @db.Uuid
  noteId     String    @map("note_id") @db.Uuid
  reactionId String    @map("reaction_id") @db.Uuid
  createdBy  String    @map("created_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  meta       Json?
  user       User      @relation(fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  note       Note      @relation(fields: [noteId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reaction   Reaction  @relation(fields: [reactionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([noteId, reactionId, createdBy], map: "note_reaction_uniq", where: raw("(deleted_at IS NULL)"))
  @@index([createdAt])
  @@index([createdBy])
  @@index([deletedAt])
  @@index([meta], type: Gin)
  @@index([noteId])
  @@index([reactionId])
  @@map("note_reaction")
}

model NoteTag {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seq       String    @unique @default(dbgenerated("uuidv7_now()")) @db.Uuid
  noteId    String    @map("note_id") @db.Uuid
  tagId     String    @map("tag_id") @db.Uuid
  createdBy String    @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  meta      Json?
  user      User      @relation(fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  note      Note      @relation(fields: [noteId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([noteId, tagId], map: "note_tag_uniq", where: raw("(deleted_at IS NULL)"))
  @@index([createdAt])
  @@index([createdBy])
  @@index([deletedAt])
  @@index([meta], type: Gin)
  @@index([noteId])
  @@index([tagId])
  @@map("note_tag")
}

model NoteUser {
  id                          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seq                         String    @unique @default(dbgenerated("uuidv7_now()")) @db.Uuid
  noteId                      String    @map("note_id") @db.Uuid
  userId                      String    @map("user_id") @db.Uuid
  createdBy                   String    @map("created_by") @db.Uuid
  createdAt                   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt                   DateTime? @map("deleted_at") @db.Timestamptz(6)
  meta                        Json?
  creator User      @relation("NoteUserCreator", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  note                        Note      @relation(fields: [noteId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  member    User      @relation("NoteUserMember", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([noteId, userId], map: "note_user_uniq", where: raw("(deleted_at IS NULL)"))
  @@index([createdAt])
  @@index([createdBy])
  @@index([deletedAt])
  @@index([meta], type: Gin)
  @@index([noteId])
  @@index([userId])
  @@map("note_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Reaction {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
