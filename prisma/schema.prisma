  user      User?      @relation("userTouser", fields: [by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  otherUser User[]     @relation("userTouser")

  @@index([at])
  @@index([by])
  @@index([deletedAt])
  @@index([meta], type: Gin)
  @@map("user")
}
