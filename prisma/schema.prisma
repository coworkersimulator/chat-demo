/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model User {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seq       String     @unique @default(dbgenerated("uuidv7_now()")) @db.Uuid
  username  String     @unique
  name      String?
  by        String?    @db.Uuid
  at        DateTime   @default(now()) @db.Timestamptz(6)
  deletedAt DateTime?  @map("deleted_at") @db.Timestamptz(6)
  meta      Json?
  file      File[]
  note      Note[]
  reaction  Reaction[]
  asRels    Rel[]      @relation("rel_as_user_idTouser")
  byRels    Rel[]      @relation("rel_byTouser")
  onRels    Rel[]      @relation("rel_on_user_idTouser")
